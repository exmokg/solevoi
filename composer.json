{
    "name": "sitetool/sitetool",
    "description": "Universal site cloning and data extraction tool",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-sqlite3": "*",
        "ext-pcntl": "*",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "SiteTool\&quot;: "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SiteTool\\Tests\&quot;: "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyze": "phpstan analyse src tests",
        "worker": "php graber.php worker",
        "queue:stats": "php graber.php queue:stats",
        "queue:clear": "php graber.php queue:clear"
    },
    "config": {
        "sort-packages": true
    }
}